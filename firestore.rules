rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        ("email" in request.auth.token && (
          request.auth.token.email == "grizouu45@gmail.com" ||
          request.auth.token.email == "sigvafevzican@gmail.com" ||
          request.auth.token.email == "grizouu45@GMAIL.COM" ||
          request.auth.token.email == "sigvafevzican@GMAIL.COM"
        )) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    function isValidGame(data) {
      return data.keys().hasAll(['title', 'description', 'imageUrl', 'category', 'createdAt', 'updatedAt']) &&
             data.title is string && data.title.size() <= 150 &&
             data.description is string && data.description.size() <= 2000 &&
             data.imageUrl is string &&
             data.category is string && data.category.size() <= 50 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /site_stats/{statId} {
      allow read: if true;
      allow write: if true;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /games/{gameId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])
      );
    }
    
    match /weeklyQuestions/{questionId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes'])
      );
    }
    
    match /giveaways/{giveawayId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isSignedIn();
    }
    
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']));
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow update, delete: if isAdmin();
    }
  }
}
